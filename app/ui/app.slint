// nairobi2 — permissionless Nostr ridesharing, Android-first Slint UI.
//
// Single window, screen switched by the `screen` property the controller sets:
//   0 Home · 1 Request · 2 Waiting · 3 DriverList · 4 Trip · 5 Chat · 6 Settings
//
// All displayed data is pushed from Rust as ready-to-render strings/models; all
// interaction flows back through callbacks. Icon-first, large fonts, big tap
// targets — the audience may be low-literacy, so numerals and pictograms lead.

import { LineEdit, ScrollView, ListView, Palette } from "std-widgets.slint";

// One nearby ride offer shown to a driver. Mirrors `engine::Offer` (distances
// pre-formatted by Rust; `request_id` is the stable id used by take-ride).
export struct OfferItem {
    request-id: string,
    passenger-name: string,
    pickup-distance: string,   // formatted, e.g. "1.2 km away"
    trip-distance: string,     // formatted, e.g. "10 km trip"
    rate: string,              // formatted rate/km
    earnings: string,          // big number, e.g. "480"
    currency: string,
}

// One chat message in a matched ride (mirrors `engine::ChatMessage`).
export struct ChatItem {
    from-me: bool,
    text: string,
}

global Theme {
    out property <color> bg: #0f1117;
    out property <color> card: #1a1d27;
    out property <color> card-alt: #232736;
    out property <color> accent: #16a34a;       // a "go" green — this is a ride app
    out property <color> accent-dim: #128040;
    out property <color> text: #e8eaf2;
    out property <color> muted: #9aa0b4;
    out property <color> warn: #ffb347;
    out property <color> danger: #ff5566;
    out property <color> line: #2a2e3f;
    out property <length> pad: 16px;
    out property <length> radius: 16px;
}

component Card inherits Rectangle {
    background: Theme.card;
    border-radius: Theme.radius;
    clip: true;
}

// A large, primary action button — the dominant control on most screens.
component BigButton inherits Rectangle {
    in property <string> text;
    in property <bool> danger: false;
    in property <bool> enabled: true;
    callback clicked;
    height: 64px;
    border-radius: 16px;
    background: !root.enabled ? Theme.card-alt
        : root.danger ? (touch.pressed ? Theme.danger.darker(20%) : Theme.danger)
        : (touch.pressed ? Theme.accent-dim : Theme.accent);
    Text {
        text: root.text;
        color: root.enabled ? #ffffff : Theme.muted;
        font-size: 22px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

component SmallButton inherits Rectangle {
    in property <string> text;
    in property <bool> danger: false;
    callback clicked;
    height: 40px;
    width: label.preferred-width + 28px;
    border-radius: 12px;
    background: t.pressed ? Theme.card-alt.brighter(20%) : Theme.card-alt;
    border-width: 1px;
    border-color: root.danger ? Theme.danger.darker(10%) : Theme.line;
    label := Text {
        text: root.text;
        color: root.danger ? Theme.danger : Theme.text;
        font-size: 15px;
        font-weight: 600;
        vertical-alignment: center;
        horizontal-alignment: center;
    }
    t := TouchArea { clicked => { root.clicked(); } }
}

// A round +/- stepper used by the rate setup.
component Stepper inherits Rectangle {
    in property <string> glyph;   // "+" or "−"
    callback clicked;
    width: 56px;
    height: 56px;
    border-radius: 28px;
    background: t.pressed ? Theme.accent-dim : Theme.card-alt;
    border-width: 2px;
    border-color: Theme.accent;
    Text {
        text: root.glyph;
        color: Theme.text;
        font-size: 30px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    t := TouchArea { clicked => { root.clicked(); } }
}

// A square pictogram button (the chat quick-replies, the sort toggles).
component IconButton inherits Rectangle {
    in property <string> glyph;
    in property <bool> selected: false;
    callback clicked;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: root.selected ? Theme.accent
        : (t.pressed ? Theme.card-alt.brighter(20%) : Theme.card-alt);
    Text {
        text: root.glyph;
        font-size: 26px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    t := TouchArea { clicked => { root.clicked(); } }
}

component SectionTitle inherits Text {
    color: Theme.muted;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
}

// A back chevron at the top-left of a sub-screen.
component BackBar inherits Rectangle {
    in property <string> title;
    callback back();
    height: 56px;
    HorizontalLayout {
        padding-left: 8px;
        padding-right: Theme.pad;
        spacing: 8px;
        Rectangle {
            width: 44px;
            height: 44px;
            border-radius: 22px;
            background: t.pressed ? Theme.card-alt : transparent;
            Path {
                width: 18px;
                height: 18px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                viewbox-width: 24;
                viewbox-height: 24;
                commands: "M 15 5 L 7 12 L 15 19";
                stroke: Theme.text;
                stroke-width: 2.5px;
                stroke-line-cap: round;
                stroke-line-join: round;
            }
            t := TouchArea { clicked => { root.back(); } }
        }
        Text {
            text: root.title;
            color: Theme.text;
            font-size: 20px;
            font-weight: 800;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
}

// ------------------------------------------------------------------ map --
//
// A map Image (composed in Rust) with an overlay of pins/dots placed via
// offsets the controller sets. There is NO route polyline (by design). A
// TouchArea reports taps (relative to the centre) and drags back to Rust.
component MapView inherits Rectangle {
    in property <image> map-image;
    // Pin/dot offsets (px from the viewport centre), pushed by Rust.
    in property <bool> show-pickup;
    in property <length> pickup-dx;
    in property <length> pickup-dy;
    in property <bool> show-dropoff;
    in property <length> dropoff-dx;
    in property <length> dropoff-dy;
    in property <bool> show-self;
    in property <length> self-dx;
    in property <length> self-dy;
    in property <bool> show-other;
    in property <length> other-dx;
    in property <length> other-dy;
    in property <string> other-label;
    // Whether a tap sets the dropoff (Request screen) vs. just pans.
    in property <bool> tap-sets-dropoff: false;
    // A fixed crosshair at the viewport centre, used to pinpoint pickup/drop-off
    // on the Request screen (pan the map under it, then confirm).
    in property <bool> show-center-pin: false;

    callback tapped(length, length);  // px relative to centre
    callback panned(length, length);
    callback viewport(length, length);
    callback zoom-in();
    callback zoom-out();

    private property <length> pan-x: 0;
    private property <length> pan-y: 0;

    clip: true;
    background: Theme.card-alt;

    Image {
        x: root.pan-x;
        y: root.pan-y;
        width: 100%;
        height: 100%;
        source: root.map-image;
        image-fit: fill;
    }

    map-touch := TouchArea {
        moved => {
            root.pan-x = self.mouse-x - self.pressed-x;
            root.pan-y = self.mouse-y - self.pressed-y;
        }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.up) {
                // A negligible drag is a tap; otherwise it's a pan.
                if (Math.abs(root.pan-x / 1px) < 6 && Math.abs(root.pan-y / 1px) < 6) {
                    root.tapped(self.mouse-x - parent.width / 2, self.mouse-y - parent.height / 2);
                } else {
                    root.panned(root.pan-x, root.pan-y);
                }
                root.pan-x = 0;
                root.pan-y = 0;
            } else if (e.kind == PointerEventKind.cancel) {
                root.pan-x = 0;
                root.pan-y = 0;
            }
        }
    }

    // Report the viewport so Rust composes the right tile set.
    init => { root.viewport(self.width, self.height); }
    changed width => { root.viewport(self.width, self.height); }
    changed height => { root.viewport(self.width, self.height); }

    // ---- pins & dots (offset from centre; follow the live pan) ----
    if root.show-pickup : Text {
        x: parent.width / 2 + root.pickup-dx + root.pan-x - self.width / 2;
        y: parent.height / 2 + root.pickup-dy + root.pan-y - self.height;
        text: "📍";
        font-size: 30px;
    }
    if root.show-dropoff : Text {
        x: parent.width / 2 + root.dropoff-dx + root.pan-x - self.width / 2;
        y: parent.height / 2 + root.dropoff-dy + root.pan-y - self.height;
        text: "🏁";
        font-size: 30px;
    }
    if root.show-self : Rectangle {
        x: parent.width / 2 + root.self-dx + root.pan-x - self.width / 2;
        y: parent.height / 2 + root.self-dy + root.pan-y - self.height / 2;
        width: 20px;
        height: 20px;
        border-radius: 10px;
        background: #3b82f6;
        border-width: 3px;
        border-color: #ffffff;
    }
    if root.show-other : Rectangle {
        x: parent.width / 2 + root.other-dx + root.pan-x - self.width / 2;
        y: parent.height / 2 + root.other-dy + root.pan-y - self.height / 2;
        width: 22px;
        height: 22px;
        border-radius: 11px;
        background: Theme.accent;
        border-width: 3px;
        border-color: #ffffff;
        Rectangle {
            y: -24px;
            x: parent.width / 2 - self.width / 2;
            width: olbl.preferred-width + 12px;
            height: 20px;
            border-radius: 10px;
            background: #000000bb;
            olbl := Text {
                text: root.other-label;
                color: #ffffff;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    // Fixed centre crosshair (pinpoint helper). Stays at the viewport centre as
    // the map pans beneath it; non-interactive so it never blocks a pan/tap.
    if root.show-center-pin : Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 38px;
        height: 38px;
        // outer ring
        Rectangle {
            width: 100%;
            height: 100%;
            border-radius: self.width / 2;
            border-width: 3px;
            border-color: Theme.accent;
            background: #16a34a22;
        }
        // centre dot (the exact point)
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 7px;
            height: 7px;
            border-radius: 3.5px;
            background: Theme.accent;
        }
    }

    // zoom controls (right edge)
    VerticalLayout {
        x: parent.width - self.width - 12px;
        y: 12px;
        width: 44px;
        spacing: 8px;
        Rectangle {
            width: 44px; height: 44px; border-radius: 22px;
            background: zin.pressed ? Theme.card-alt.brighter(20%) : #1a1d27dd;
            border-width: 1px; border-color: Theme.line;
            Text { text: "+"; color: Theme.text; font-size: 24px; font-weight: 800;
                horizontal-alignment: center; vertical-alignment: center; }
            zin := TouchArea { clicked => { root.zoom-in(); } }
        }
        Rectangle {
            width: 44px; height: 44px; border-radius: 22px;
            background: zout.pressed ? Theme.card-alt.brighter(20%) : #1a1d27dd;
            border-width: 1px; border-color: Theme.line;
            Text { text: "−"; color: Theme.text; font-size: 24px; font-weight: 800;
                horizontal-alignment: center; vertical-alignment: center; }
            zout := TouchArea { clicked => { root.zoom-out(); } }
        }
    }

    if root.tap-sets-dropoff : Rectangle {
        x: (parent.width - self.width) / 2;
        y: 12px;
        width: hint.preferred-width + 20px;
        height: 30px;
        border-radius: 15px;
        background: #000000bb;
        hint := Text {
            text: "Centre the ◎ on a spot, then Set pickup / drop-off";
            color: #ffffff;
            font-size: 13px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // OSM attribution — required by the tile licence.
    Rectangle {
        x: parent.width - self.width - 4px;
        y: parent.height - self.height - 4px;
        width: attribution.preferred-width + 10px;
        height: 16px;
        border-radius: 4px;
        background: #000000aa;
        attribution := Text {
            text: "© OpenStreetMap contributors";
            color: #ffffff;
            font-size: 9px;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
}

// --------------------------------------------------------------- screens --

component HomeScreen inherits Rectangle {
    callback need-ride();
    callback go-driving();
    VerticalLayout {
        padding: Theme.pad;
        spacing: 16px;
        alignment: center;
        Text {
            text: "nairobi 🚖";
            color: Theme.text;
            font-size: 34px;
            font-weight: 900;
            horizontal-alignment: center;
        }
        Text {
            text: "What do you want to do?";
            color: Theme.muted;
            font-size: 16px;
            horizontal-alignment: center;
        }
        Card {
            height: 200px;
            background: ndt.pressed ? Theme.accent-dim : Theme.accent;
            VerticalLayout {
                alignment: center;
                spacing: 8px;
                Text { text: "🧍"; font-size: 64px; horizontal-alignment: center; }
                Text { text: "I need a ride"; color: #ffffff; font-size: 24px;
                    font-weight: 800; horizontal-alignment: center; }
            }
            ndt := TouchArea { clicked => { root.need-ride(); } }
        }
        Card {
            height: 200px;
            background: gdt.pressed ? Theme.card-alt.brighter(15%) : Theme.card-alt;
            VerticalLayout {
                alignment: center;
                spacing: 8px;
                Text { text: "🚗"; font-size: 64px; horizontal-alignment: center; }
                Text { text: "I'm driving"; color: Theme.text; font-size: 24px;
                    font-weight: 800; horizontal-alignment: center; }
            }
            gdt := TouchArea { clicked => { root.go-driving(); } }
        }
    }
}

component RequestScreen inherits Rectangle {
    // map passthrough
    in property <image> map-image;
    in property <bool> show-pickup;
    in property <length> pickup-dx;
    in property <length> pickup-dy;
    in property <bool> show-dropoff;
    in property <length> dropoff-dx;
    in property <length> dropoff-dy;
    in property <bool> show-self;
    in property <length> self-dx;
    in property <length> self-dy;
    // rate setup + preview
    in property <string> start-rate;
    in property <string> max-rate;
    in property <string> currency;
    in property <string> distance-preview;
    in property <string> fare-preview;
    in property <bool> can-request;

    callback back();
    callback map-tapped(length, length);
    callback map-panned(length, length);
    callback map-viewport(length, length);
    callback map-zoom-in();
    callback map-zoom-out();
    callback search(string);
    callback set-pickup-here();
    callback set-dropoff-here();
    callback start-rate-inc();
    callback start-rate-dec();
    callback max-rate-inc();
    callback max-rate-dec();
    callback request-ride();

    VerticalLayout {
        BackBar { title: "Request a ride"; back => { root.back(); } }

        // Map fills the top half (map-first).
        Rectangle {
            vertical-stretch: 1;
            MapView {
                width: 100%;
                height: 100%;
                map-image: root.map-image;
                tap-sets-dropoff: true;
                show-center-pin: true;
                show-pickup: root.show-pickup;
                pickup-dx: root.pickup-dx;
                pickup-dy: root.pickup-dy;
                show-dropoff: root.show-dropoff;
                dropoff-dx: root.dropoff-dx;
                dropoff-dy: root.dropoff-dy;
                show-self: root.show-self;
                self-dx: root.self-dx;
                self-dy: root.self-dy;
                tapped(x, y) => { root.map-tapped(x, y); }
                panned(x, y) => { root.map-panned(x, y); }
                viewport(w, h) => { root.map-viewport(w, h); }
                zoom-in => { root.map-zoom-in(); }
                zoom-out => { root.map-zoom-out(); }
            }
        }

        // Controls below the map.
        Rectangle {
            background: Theme.bg;
            VerticalLayout {
                padding: Theme.pad;
                spacing: 12px;

                search-input := LineEdit {
                    placeholder-text: "Search a place (optional)…";
                    accepted(t) => { root.search(t); }
                }

                // Pinpoint controls: pan the map so the centre crosshair sits on
                // the exact spot, then drop the pickup (🧍) or drop-off (🏁) there.
                HorizontalLayout {
                    spacing: 8px;
                    SmallButton {
                        text: "🧍 Set pickup";
                        clicked => { root.set-pickup-here(); }
                    }
                    SmallButton {
                        text: "🏁 Set drop-off";
                        clicked => { root.set-dropoff-here(); }
                    }
                }

                // start rate stepper
                HorizontalLayout {
                    spacing: 12px;
                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;
                        Text { text: "Start rate /km"; color: Theme.muted; font-size: 13px; }
                        Text { text: root.start-rate + " " + root.currency; color: Theme.text;
                            font-size: 22px; font-weight: 800; }
                    }
                    Stepper { glyph: "−"; clicked => { root.start-rate-dec(); } }
                    Stepper { glyph: "+"; clicked => { root.start-rate-inc(); } }
                }
                // max rate stepper
                HorizontalLayout {
                    spacing: 12px;
                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;
                        Text { text: "Max rate /km"; color: Theme.muted; font-size: 13px; }
                        Text { text: root.max-rate + " " + root.currency; color: Theme.text;
                            font-size: 22px; font-weight: 800; }
                    }
                    Stepper { glyph: "−"; clicked => { root.max-rate-dec(); } }
                    Stepper { glyph: "+"; clicked => { root.max-rate-inc(); } }
                }

                // live distance + fare preview
                Card {
                    background: Theme.card-alt;
                    HorizontalLayout {
                        padding: 12px;
                        spacing: 16px;
                        VerticalLayout {
                            Text { text: "Distance"; color: Theme.muted; font-size: 12px; }
                            Text { text: root.distance-preview; color: Theme.text;
                                font-size: 18px; font-weight: 700; }
                        }
                        VerticalLayout {
                            horizontal-stretch: 1;
                            Text { text: "Est. fare (at start rate)"; color: Theme.muted; font-size: 12px; }
                            Text { text: root.fare-preview + " " + root.currency; color: Theme.accent;
                                font-size: 22px; font-weight: 800; }
                        }
                    }
                }

                BigButton {
                    text: "REQUEST RIDE";
                    enabled: root.can-request;
                    clicked => { root.request-ride(); }
                }
            }
        }
    }
}

component WaitingScreen inherits Rectangle {
    in property <image> map-image;
    in property <bool> show-pickup;
    in property <length> pickup-dx;
    in property <length> pickup-dy;
    in property <bool> show-dropoff;
    in property <length> dropoff-dx;
    in property <length> dropoff-dy;
    in property <bool> show-self;
    in property <length> self-dx;
    in property <length> self-dy;
    in property <string> current-rate;
    in property <string> currency;
    in property <string> fare-estimate;
    in property <string> elapsed;       // "1:23"
    in property <string> status-line;   // "Searching…" / "At max rate"
    in property <bool> at-max;
    in property <string> countdown;     // "↑ rate rises in 12s" (empty once at max)

    callback map-viewport(length, length);
    callback map-panned(length, length);
    callback map-zoom-in();
    callback map-zoom-out();
    callback cancel();

    VerticalLayout {
        Rectangle {
            vertical-stretch: 1;
            MapView {
                width: 100%;
                height: 100%;
                map-image: root.map-image;
                show-pickup: root.show-pickup;
                pickup-dx: root.pickup-dx;
                pickup-dy: root.pickup-dy;
                show-dropoff: root.show-dropoff;
                dropoff-dx: root.dropoff-dx;
                dropoff-dy: root.dropoff-dy;
                show-self: root.show-self;
                self-dx: root.self-dx;
                self-dy: root.self-dy;
                panned(x, y) => { root.map-panned(x, y); }
                viewport(w, h) => { root.map-viewport(w, h); }
                zoom-in => { root.map-zoom-in(); }
                zoom-out => { root.map-zoom-out(); }
            }
        }
        Rectangle {
            background: Theme.bg;
            VerticalLayout {
                padding: Theme.pad;
                spacing: 8px;
                Text {
                    text: root.status-line;
                    color: root.at-max ? Theme.warn : Theme.muted;
                    font-size: 16px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                // The dominant element: the live current rate.
                Text {
                    text: root.current-rate;
                    color: Theme.accent;
                    font-size: 72px;
                    font-weight: 900;
                    horizontal-alignment: center;
                }
                Text {
                    text: root.currency + " /km · est. fare " + root.fare-estimate + " " + root.currency;
                    color: Theme.text;
                    font-size: 15px;
                    horizontal-alignment: center;
                }
                // Live countdown to the next rate increase (hidden once at max).
                if root.countdown != "" : Text {
                    text: root.countdown;
                    color: Theme.accent;
                    font-size: 16px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                Text {
                    text: "⏱ " + root.elapsed;
                    color: Theme.muted;
                    font-size: 15px;
                    horizontal-alignment: center;
                }
                BigButton {
                    text: "CANCEL";
                    danger: true;
                    clicked => { root.cancel(); }
                }
            }
        }
    }
}

component OfferCard inherits Card {
    in property <OfferItem> item;
    callback take();
    background: Theme.card;
    HorizontalLayout {
        padding: Theme.pad;
        spacing: 12px;
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            Text { text: item.passenger-name; color: Theme.text; font-size: 18px;
                font-weight: 800; overflow: elide; }
            Text { text: "🧍→ " + item.pickup-distance; color: Theme.muted; font-size: 14px; }
            Text { text: "🏁 " + item.trip-distance + " · " + item.rate; color: Theme.muted; font-size: 14px; }
        }
        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text { text: item.earnings; color: Theme.accent; font-size: 30px;
                font-weight: 900; horizontal-alignment: center; }
            Text { text: item.currency; color: Theme.muted; font-size: 12px;
                horizontal-alignment: center; }
        }
        VerticalLayout {
            alignment: center;
            SmallButton { text: "TAKE"; clicked => { root.take(); } }
        }
    }
}

component DriverListScreen inherits Rectangle {
    in property <[OfferItem]> offers;
    in property <int> sort-key;        // 0 pickup · 1 earnings · 2 rate · 3 trip
    in property <string> status-line;

    callback back();
    callback set-sort(int);
    callback take-ride(string);

    VerticalLayout {
        BackBar { title: "Nearby rides"; back => { root.back(); } }

        // sort toggle: three icon buttons (the task asks for 3)
        HorizontalLayout {
            padding-left: Theme.pad;
            padding-right: Theme.pad;
            spacing: 10px;
            alignment: start;
            IconButton { glyph: "📍"; selected: root.sort-key == 0; clicked => { root.set-sort(0); } }
            IconButton { glyph: "💰"; selected: root.sort-key == 1; clicked => { root.set-sort(1); } }
            IconButton { glyph: "🏁"; selected: root.sort-key == 3; clicked => { root.set-sort(3); } }
            VerticalLayout {
                alignment: center;
                Text { text: "sort"; color: Theme.muted; font-size: 12px; }
            }
        }

        if root.offers.length == 0 : VerticalLayout {
            padding: Theme.pad;
            alignment: start;
            Text {
                text: root.status-line;
                color: Theme.muted;
                font-size: 15px;
                wrap: word-wrap;
                horizontal-alignment: center;
            }
        }

        ListView {
            vertical-stretch: 1;
            for o in root.offers : Rectangle {
                height: 96px;
                VerticalLayout {
                    padding-left: Theme.pad;
                    padding-right: Theme.pad;
                    padding-bottom: 8px;
                    OfferCard {
                        item: o;
                        take => { root.take-ride(o.request-id); }
                    }
                }
            }
        }
    }
}

component TripScreen inherits Rectangle {
    in property <image> map-image;
    in property <bool> show-self;
    in property <length> self-dx;
    in property <length> self-dy;
    in property <bool> show-other;
    in property <length> other-dx;
    in property <length> other-dy;
    in property <string> other-label;
    in property <bool> show-pickup;
    in property <length> pickup-dx;
    in property <length> pickup-dy;
    in property <bool> show-dropoff;
    in property <length> dropoff-dx;
    in property <length> dropoff-dy;
    in property <string> banner;
    in property <bool> is-driver;    // the NAVIGATE button is driver-only

    callback map-viewport(length, length);
    callback map-panned(length, length);
    callback map-zoom-in();
    callback map-zoom-out();
    callback open-chat();
    callback navigate();
    callback complete();

    VerticalLayout {
        Rectangle {
            vertical-stretch: 1;
            MapView {
                width: 100%;
                height: 100%;
                map-image: root.map-image;
                show-self: root.show-self;
                self-dx: root.self-dx;
                self-dy: root.self-dy;
                show-other: root.show-other;
                other-dx: root.other-dx;
                other-dy: root.other-dy;
                other-label: root.other-label;
                show-pickup: root.show-pickup;
                pickup-dx: root.pickup-dx;
                pickup-dy: root.pickup-dy;
                show-dropoff: root.show-dropoff;
                dropoff-dx: root.dropoff-dx;
                dropoff-dy: root.dropoff-dy;
                panned(x, y) => { root.map-panned(x, y); }
                viewport(w, h) => { root.map-viewport(w, h); }
                zoom-in => { root.map-zoom-in(); }
                zoom-out => { root.map-zoom-out(); }
            }
            // status banner over the top of the map
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: 12px;
                width: min(parent.width - 24px, bannerlbl.preferred-width + 24px);
                height: 36px;
                border-radius: 18px;
                background: #000000cc;
                bannerlbl := Text {
                    text: root.banner;
                    color: #ffffff;
                    font-size: 15px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
        Rectangle {
            background: Theme.bg;
            VerticalLayout {
                padding: Theme.pad;
                spacing: 12px;
                HorizontalLayout {
                    spacing: 12px;
                    if root.is-driver : BigButton {
                        text: "🧭 NAVIGATE";
                        horizontal-stretch: 1;
                        clicked => { root.navigate(); }
                    }
                    Rectangle {
                        width: 64px;
                        height: 64px;
                        border-radius: 16px;
                        background: ct.pressed ? Theme.card-alt.brighter(20%) : Theme.card-alt;
                        Text { text: "💬"; font-size: 28px;
                            horizontal-alignment: center; vertical-alignment: center; }
                        ct := TouchArea { clicked => { root.open-chat(); } }
                    }
                }
                BigButton {
                    text: "✅ COMPLETE TRIP";
                    clicked => { root.complete(); }
                }
            }
        }
    }
}

component ChatScreen inherits Rectangle {
    in property <[ChatItem]> messages;
    callback back();
    callback quick-reply(string);   // canned text
    callback send(string);

    VerticalLayout {
        BackBar { title: "Chat"; back => { root.back(); } }

        chat-list := ListView {
            vertical-stretch: 1;
            for m in root.messages : Rectangle {
                // Row height follows the wrapped text. The text is capped to a
                // fraction of the list width (a fixed value, NOT derived from the
                // bubble) so there's no circular width constraint. The bubble is
                // declared first so it paints behind the text.
                height: msgtext.preferred-height + 28px;
                bubble := Rectangle {
                    x: msgtext.x - 12px;
                    y: 6px;
                    width: msgtext.width + 24px;
                    height: msgtext.preferred-height + 16px;
                    border-radius: 14px;
                    background: m.from-me ? Theme.accent : Theme.card-alt;
                }
                msgtext := Text {
                    // Right-align our own messages, left-align the other side.
                    x: m.from-me
                        ? parent.width - self.width - Theme.pad - 12px
                        : Theme.pad + 12px;
                    y: 14px;
                    width: chat-list.width * 0.66;
                    text: m.text;
                    color: m.from-me ? #ffffff : Theme.text;
                    font-size: 15px;
                    wrap: word-wrap;
                    horizontal-alignment: left;
                }
            }
        }

        // pictogram quick replies
        Rectangle {
            background: Theme.bg;
            VerticalLayout {
                padding: Theme.pad;
                spacing: 10px;
                HorizontalLayout {
                    spacing: 8px;
                    alignment: space-between;
                    IconButton { glyph: "📍"; clicked => { root.quick-reply("I'm here at the pickup."); } }
                    IconButton { glyph: "⏱"; clicked => { root.quick-reply("Give me a few minutes."); } }
                    IconButton { glyph: "❓"; clicked => { root.quick-reply("Where are you?"); } }
                    IconButton { glyph: "👍"; clicked => { root.quick-reply("OK, on my way."); } }
                    IconButton { glyph: "📞"; clicked => { root.quick-reply("Please call me."); } }
                }
                HorizontalLayout {
                    spacing: 8px;
                    chat-input := LineEdit {
                        horizontal-stretch: 1;
                        placeholder-text: "Type a message…";
                        accepted(t) => {
                            if (t != "") { root.send(t); }
                            self.text = "";
                        }
                    }
                    SmallButton {
                        text: "Send";
                        clicked => {
                            if (chat-input.text != "") { root.send(chat-input.text); }
                            chat-input.text = "";
                        }
                    }
                }
            }
        }
    }
}

component SettingsScreen inherits Rectangle {
    in property <[string]> relays;
    in property <string> currency;
    in property <string> npub;
    in property <string> federation-status;
    callback back();
    callback add-relay(string);
    callback remove-relay(string);
    callback set-federation(string);

    VerticalLayout {
        BackBar { title: "Settings"; back => { root.back(); } }
        ScrollView {
            vertical-stretch: 1;
            VerticalLayout {
                padding: Theme.pad;
                spacing: 12px;
                alignment: start;

                SectionTitle { text: "YOUR IDENTITY"; }
                Card {
                    VerticalLayout {
                        padding: Theme.pad;
                        spacing: 6px;
                        Text { text: "Public key (npub)"; color: Theme.muted; font-size: 12px; }
                        Text {
                            text: root.npub == "" ? "generated on first launch" : root.npub;
                            color: Theme.text;
                            font-size: 13px;
                            wrap: char-wrap;
                        }
                    }
                }

                SectionTitle { text: "CURRENCY"; }
                Card {
                    VerticalLayout {
                        padding: Theme.pad;
                        Text { text: root.currency; color: Theme.text; font-size: 18px; font-weight: 700; }
                    }
                }

                SectionTitle { text: "RELAYS"; }
                Card {
                    VerticalLayout {
                        padding: 8px;
                        for r in root.relays : HorizontalLayout {
                            padding: 8px;
                            spacing: 10px;
                            Text {
                                text: r;
                                color: Theme.text;
                                font-size: 13px;
                                overflow: elide;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            SmallButton { text: "Remove"; danger: true; clicked => { root.remove-relay(r); } }
                        }
                    }
                }
                Card {
                    VerticalLayout {
                        padding: Theme.pad;
                        spacing: 10px;
                        relay-input := LineEdit { placeholder-text: "wss://relay.example.com"; }
                        SmallButton {
                            text: "Add relay";
                            clicked => {
                                root.add-relay(relay-input.text);
                                relay-input.text = "";
                            }
                        }
                    }
                }

                SectionTitle { text: "BITCOIN WALLET (FEDIMINT)"; }
                Card {
                    VerticalLayout {
                        padding: Theme.pad;
                        spacing: 8px;
                        Text {
                            text: "Federation: " + root.federation-status;
                            color: Theme.text;
                            font-size: 13px;
                            wrap: word-wrap;
                        }
                        Text {
                            text: "Paste a Fedimint federation invite to fund a real Bitcoin / Lightning wallet. Takes effect on the next launch.";
                            color: Theme.muted;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                        fed-input := LineEdit { placeholder-text: "fed11…"; }
                        SmallButton {
                            text: "Save federation";
                            clicked => {
                                root.set-federation(fed-input.text);
                                fed-input.text = "";
                            }
                        }
                    }
                }

                SectionTitle { text: "ABOUT"; }
                Text {
                    text: "nairobi is a permissionless rideshare over Nostr. There is no company in the middle: passengers post an escalating-rate request, drivers nearby take it first-come, and the two talk directly. Locations and chat are end-to-end encrypted.";
                    color: Theme.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }
    }
}

// The Bitcoin / Lightning wallet: balance, receive (Lightning invoice + on-chain
// address), and send (pay an invoice, M-Pesa payout by phone, on-chain send).
// Wallet operations need typed input (invoices, addresses, phone numbers), so
// this screen is more text-heavy than the rest of the icon-first UI.
component WalletScreen inherits Rectangle {
    in property <string> balance;
    in property <string> status;
    in property <string> invoice;
    in property <string> deposit-address;
    in property <bool> busy;

    callback back();
    callback refresh();
    callback receive-lightning(string);
    callback receive-onchain();
    callback pay-invoice(string);
    callback pay-mpesa(string, string);
    callback send-onchain(string, string);

    VerticalLayout {
        BackBar { title: "Wallet"; back => { root.back(); } }
        ScrollView {
            vertical-stretch: 1;
            VerticalLayout {
                padding: Theme.pad;
                spacing: 14px;
                alignment: start;

                // ---- balance ----
                Card {
                    background: Theme.card-alt;
                    VerticalLayout {
                        padding: Theme.pad;
                        spacing: 6px;
                        HorizontalLayout {
                            Text {
                                text: "BALANCE";
                                color: Theme.muted;
                                font-size: 13px;
                                font-weight: 700;
                                letter-spacing: 1px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            Rectangle {
                                width: 44px;
                                height: 32px;
                                border-radius: 10px;
                                background: refresh-t.pressed ? Theme.card.brighter(20%) : transparent;
                                Text {
                                    text: root.busy ? "⏳" : "⟳";
                                    color: Theme.accent;
                                    font-size: 20px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                refresh-t := TouchArea { clicked => { root.refresh(); } }
                            }
                        }
                        HorizontalLayout {
                            alignment: start;
                            spacing: 8px;
                            Text { text: root.balance; color: Theme.accent; font-size: 48px; font-weight: 900; }
                            Text { text: "sat"; color: Theme.muted; font-size: 18px; vertical-alignment: bottom; }
                        }
                        if root.status != "" : Text {
                            text: root.status;
                            color: Theme.text;
                            font-size: 13px;
                            wrap: word-wrap;
                        }
                    }
                }

                // ---- receive / fund ----
                SectionTitle { text: "RECEIVE / FUND"; }
                Card {
                    VerticalLayout {
                        padding: Theme.pad;
                        spacing: 10px;
                        Text { text: "⚡ Lightning"; color: Theme.text; font-size: 16px; font-weight: 700; }
                        HorizontalLayout {
                            spacing: 8px;
                            ln-amt := LineEdit {
                                horizontal-stretch: 1;
                                placeholder-text: "amount in sat";
                                input-type: InputType.number;
                            }
                            SmallButton { text: "Get invoice"; clicked => { root.receive-lightning(ln-amt.text); } }
                        }
                        if root.invoice != "" : Text {
                            text: root.invoice;
                            color: Theme.muted;
                            font-size: 11px;
                            wrap: char-wrap;
                        }

                        Rectangle { height: 1px; background: Theme.line; }

                        Text { text: "₿ On-chain"; color: Theme.text; font-size: 16px; font-weight: 700; }
                        SmallButton { text: "Get deposit address"; clicked => { root.receive-onchain(); } }
                        if root.deposit-address != "" : Text {
                            text: root.deposit-address;
                            color: Theme.muted;
                            font-size: 11px;
                            wrap: char-wrap;
                        }
                    }
                }

                // ---- send: pay an invoice ----
                SectionTitle { text: "SEND"; }
                Card {
                    VerticalLayout {
                        padding: Theme.pad;
                        spacing: 10px;
                        Text { text: "⚡ Pay a Lightning invoice"; color: Theme.text; font-size: 16px; font-weight: 700; }
                        inv-in := LineEdit { placeholder-text: "lnbc…"; }
                        SmallButton {
                            text: "Pay invoice";
                            clicked => {
                                root.pay-invoice(inv-in.text);
                                inv-in.text = "";
                            }
                        }
                    }
                }

                // ---- send: M-Pesa payout ----
                SectionTitle { text: "M-PESA PAYOUT"; }
                Card {
                    VerticalLayout {
                        padding: Theme.pad;
                        spacing: 10px;
                        Text { text: "📱 Send to a phone (KES)"; color: Theme.text; font-size: 16px; font-weight: 700; }
                        Text {
                            text: "Converts sat → KES via bitcoin.co.ke and pays M-Pesa.";
                            color: Theme.muted;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                        phone-in := LineEdit { placeholder-text: "07XX XXX XXX"; input-type: InputType.number; }
                        HorizontalLayout {
                            spacing: 8px;
                            mpesa-amt := LineEdit {
                                horizontal-stretch: 1;
                                placeholder-text: "amount in sat";
                                input-type: InputType.number;
                            }
                            SmallButton { text: "Send"; clicked => { root.pay-mpesa(phone-in.text, mpesa-amt.text); } }
                        }
                    }
                }

                // ---- send: on-chain ----
                SectionTitle { text: "ON-CHAIN SEND"; }
                Card {
                    VerticalLayout {
                        padding: Theme.pad;
                        spacing: 10px;
                        addr-in := LineEdit { placeholder-text: "bc1…"; }
                        HorizontalLayout {
                            spacing: 8px;
                            oc-amt := LineEdit {
                                horizontal-stretch: 1;
                                placeholder-text: "amount in sat";
                                input-type: InputType.number;
                            }
                            SmallButton { text: "Send ₿"; clicked => { root.send-onchain(addr-in.text, oc-amt.text); } }
                        }
                    }
                }
            }
        }
    }
}

// ----------------------------------------------------------- main window --

export component MainWindow inherits Window {
    title: "nairobi";
    background: Theme.bg;
    preferred-width: 412px;
    preferred-height: 915px;
    default-font-size: 15px;

    // Which screen is shown (set by the controller).
    in property <int> screen: 0;

    // ---- map (shared by Request / Waiting / Trip) ----
    in property <image> map-image;
    in property <bool> map-show-pickup;
    in property <length> map-pickup-dx;
    in property <length> map-pickup-dy;
    in property <bool> map-show-dropoff;
    in property <length> map-dropoff-dx;
    in property <length> map-dropoff-dy;
    in property <bool> map-show-self;
    in property <length> map-self-dx;
    in property <length> map-self-dy;
    in property <bool> map-show-other;
    in property <length> map-other-dx;
    in property <length> map-other-dy;
    in property <string> map-other-label;

    // ---- request screen ----
    in property <string> start-rate: "30";
    in property <string> max-rate: "120";
    in property <string> currency: "KES";
    in property <string> distance-preview: "—";
    in property <string> fare-preview: "—";
    in property <bool> can-request: false;

    // ---- waiting screen ----
    in property <string> waiting-rate: "0";
    in property <string> waiting-fare: "0";
    in property <string> waiting-elapsed: "0:00";
    in property <string> waiting-status: "Searching…";
    in property <bool> waiting-at-max: false;
    in property <string> waiting-countdown: "";

    // ---- driver list ----
    in property <[OfferItem]> offers;
    in property <int> sort-key: 0;
    in property <string> driver-status: "Looking for nearby ride requests…";

    // ---- trip ----
    in property <string> trip-banner: "";
    in property <bool> trip-is-driver: false;

    // ---- chat ----
    in property <[ChatItem]> messages;

    // ---- settings ----
    in property <[string]> relays;
    in property <string> npub;
    in property <string> federation-status: "Not set";

    // ---- wallet ----
    in property <string> wallet-balance: "0";
    in property <string> wallet-status: "";
    in property <string> wallet-invoice: "";
    in property <string> wallet-deposit-address: "";
    in property <bool> wallet-busy: false;

    // ---- toast ----
    in property <string> toast;

    // ---- callbacks (every user action) ----
    callback need-ride();
    callback go-driving();
    callback back-home();
    callback open-settings();

    // request
    callback search(string);
    callback set-pickup-here();
    callback set-dropoff-here();
    callback map-tapped(length, length);
    callback map-panned(length, length);
    callback map-viewport(length, length);
    callback map-zoom-in();
    callback map-zoom-out();
    callback start-rate-inc();
    callback start-rate-dec();
    callback max-rate-inc();
    callback max-rate-dec();
    callback request-ride();
    callback cancel-request();

    // driver
    callback set-sort(int);
    callback take-ride(string);

    // trip / chat (shared post-match)
    callback open-chat();
    callback close-chat();
    callback navigate();
    callback complete();
    callback send-dm(string);

    // settings
    callback add-relay(string);
    callback remove-relay(string);
    callback set-federation(string);

    // wallet
    callback open-wallet();
    callback wallet-refresh();
    callback wallet-receive-lightning(string);
    callback wallet-receive-onchain();
    callback wallet-pay-invoice(string);
    callback wallet-pay-mpesa(string, string);
    callback wallet-send-onchain(string, string);

    init => {
        Palette.color-scheme = ColorScheme.dark;
    }

    VerticalLayout {
        padding-left: root.safe-area-insets.left;
        padding-right: root.safe-area-insets.right;

        Rectangle { height: root.safe-area-insets.top; background: Theme.bg; }

        Rectangle {
            vertical-stretch: 1;
            clip: true;

            if root.screen == 0 : HomeScreen {
                need-ride => { root.need-ride(); }
                go-driving => { root.go-driving(); }
            }

            if root.screen == 1 : RequestScreen {
                map-image: root.map-image;
                show-pickup: root.map-show-pickup;
                pickup-dx: root.map-pickup-dx;
                pickup-dy: root.map-pickup-dy;
                show-dropoff: root.map-show-dropoff;
                dropoff-dx: root.map-dropoff-dx;
                dropoff-dy: root.map-dropoff-dy;
                show-self: root.map-show-self;
                self-dx: root.map-self-dx;
                self-dy: root.map-self-dy;
                start-rate: root.start-rate;
                max-rate: root.max-rate;
                currency: root.currency;
                distance-preview: root.distance-preview;
                fare-preview: root.fare-preview;
                can-request: root.can-request;
                back => { root.back-home(); }
                map-tapped(x, y) => { root.map-tapped(x, y); }
                map-panned(x, y) => { root.map-panned(x, y); }
                map-viewport(w, h) => { root.map-viewport(w, h); }
                map-zoom-in => { root.map-zoom-in(); }
                map-zoom-out => { root.map-zoom-out(); }
                search(t) => { root.search(t); }
                set-pickup-here => { root.set-pickup-here(); }
                set-dropoff-here => { root.set-dropoff-here(); }
                start-rate-inc => { root.start-rate-inc(); }
                start-rate-dec => { root.start-rate-dec(); }
                max-rate-inc => { root.max-rate-inc(); }
                max-rate-dec => { root.max-rate-dec(); }
                request-ride => { root.request-ride(); }
            }

            if root.screen == 2 : WaitingScreen {
                map-image: root.map-image;
                show-pickup: root.map-show-pickup;
                pickup-dx: root.map-pickup-dx;
                pickup-dy: root.map-pickup-dy;
                show-dropoff: root.map-show-dropoff;
                dropoff-dx: root.map-dropoff-dx;
                dropoff-dy: root.map-dropoff-dy;
                show-self: root.map-show-self;
                self-dx: root.map-self-dx;
                self-dy: root.map-self-dy;
                current-rate: root.waiting-rate;
                currency: root.currency;
                fare-estimate: root.waiting-fare;
                elapsed: root.waiting-elapsed;
                status-line: root.waiting-status;
                at-max: root.waiting-at-max;
                countdown: root.waiting-countdown;
                map-panned(x, y) => { root.map-panned(x, y); }
                map-viewport(w, h) => { root.map-viewport(w, h); }
                map-zoom-in => { root.map-zoom-in(); }
                map-zoom-out => { root.map-zoom-out(); }
                cancel => { root.cancel-request(); }
            }

            if root.screen == 3 : DriverListScreen {
                offers: root.offers;
                sort-key: root.sort-key;
                status-line: root.driver-status;
                back => { root.back-home(); }
                set-sort(k) => { root.set-sort(k); }
                take-ride(id) => { root.take-ride(id); }
            }

            if root.screen == 4 : TripScreen {
                map-image: root.map-image;
                show-self: root.map-show-self;
                self-dx: root.map-self-dx;
                self-dy: root.map-self-dy;
                show-other: root.map-show-other;
                other-dx: root.map-other-dx;
                other-dy: root.map-other-dy;
                other-label: root.map-other-label;
                show-pickup: root.map-show-pickup;
                pickup-dx: root.map-pickup-dx;
                pickup-dy: root.map-pickup-dy;
                show-dropoff: root.map-show-dropoff;
                dropoff-dx: root.map-dropoff-dx;
                dropoff-dy: root.map-dropoff-dy;
                banner: root.trip-banner;
                is-driver: root.trip-is-driver;
                map-panned(x, y) => { root.map-panned(x, y); }
                map-viewport(w, h) => { root.map-viewport(w, h); }
                map-zoom-in => { root.map-zoom-in(); }
                map-zoom-out => { root.map-zoom-out(); }
                open-chat => { root.open-chat(); }
                navigate => { root.navigate(); }
                complete => { root.complete(); }
            }

            if root.screen == 5 : ChatScreen {
                messages: root.messages;
                back => { root.close-chat(); }
                quick-reply(t) => { root.send-dm(t); }
                send(t) => { root.send-dm(t); }
            }

            if root.screen == 6 : SettingsScreen {
                relays: root.relays;
                currency: root.currency;
                npub: root.npub;
                federation-status: root.federation-status;
                back => { root.back-home(); }
                add-relay(u) => { root.add-relay(u); }
                remove-relay(u) => { root.remove-relay(u); }
                set-federation(i) => { root.set-federation(i); }
            }

            if root.screen == 7 : WalletScreen {
                balance: root.wallet-balance;
                status: root.wallet-status;
                invoice: root.wallet-invoice;
                deposit-address: root.wallet-deposit-address;
                busy: root.wallet-busy;
                back => { root.back-home(); }
                refresh => { root.wallet-refresh(); }
                receive-lightning(a) => { root.wallet-receive-lightning(a); }
                receive-onchain => { root.wallet-receive-onchain(); }
                pay-invoice(i) => { root.wallet-pay-invoice(i); }
                pay-mpesa(p, a) => { root.wallet-pay-mpesa(p, a); }
                send-onchain(addr, a) => { root.wallet-send-onchain(addr, a); }
            }
        }

        Rectangle { height: root.safe-area-insets.bottom; background: Theme.bg; }
    }

    // settings affordance on Home (top-right gear)
    if root.screen == 0 : Rectangle {
        x: parent.width - self.width - 12px - root.safe-area-insets.right;
        y: 12px + root.safe-area-insets.top;
        width: 44px;
        height: 44px;
        border-radius: 22px;
        background: gt.pressed ? Theme.card-alt : transparent;
        Text { text: "⚙"; font-size: 24px; color: Theme.text;
            horizontal-alignment: center; vertical-alignment: center; }
        gt := TouchArea { clicked => { root.open-settings(); } }
    }

    // wallet affordance on Home (top-left)
    if root.screen == 0 : Rectangle {
        x: 12px + root.safe-area-insets.left;
        y: 12px + root.safe-area-insets.top;
        width: 44px;
        height: 44px;
        border-radius: 22px;
        background: wallet-t.pressed ? Theme.card-alt : transparent;
        Text { text: "💰"; font-size: 24px;
            horizontal-alignment: center; vertical-alignment: center; }
        wallet-t := TouchArea { clicked => { root.open-wallet(); } }
    }

    if root.toast != "" : Rectangle {
        x: (parent.width - self.width) / 2;
        y: parent.height - 120px - root.safe-area-insets.bottom;
        width: min(toast-label.preferred-width + 32px, parent.width - 32px);
        height: toast-label.preferred-height + 20px;
        border-radius: 12px;
        background: #2c3040ee;
        toast-label := Text {
            text: root.toast;
            color: Theme.text;
            font-size: 14px;
            wrap: word-wrap;
            width: parent.width - 32px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
